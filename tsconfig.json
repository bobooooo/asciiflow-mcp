{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "#asciiflow/*": ["../*.ts", "../*"],
      "#asciiflow/*.js": ["../*.ts"]
    }
  },
  "include": ["src/**/*"]
}
